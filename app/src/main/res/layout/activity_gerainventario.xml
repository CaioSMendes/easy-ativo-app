<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#252525"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_logo_bsb_rfid"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inventário"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Relatório geral -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvRelatorio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cardElevation="4dp"
        app:cardCornerRadius="8dp">

        <TextView
            android:id="@+id/tvRelatorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Relatório gerado: 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="16dp"
            android:textColor="#000000"/>
    </androidx.cardview.widget.CardView>

    <!-- Resumo do último nível -->
    <LinearLayout
        android:id="@+id/llResumo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/cvRelatorio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Nome do último nível -->
        <TextView
            android:id="@+id/tvUltimoNivelNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Itens CONTAS A RECEBER: 0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:paddingBottom="8dp"/>

        <!-- Cards coloridos de status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Encontrados -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                android:layout_marginEnd="4dp"
                android:background="#E8F5E9">

                <TextView
                    android:id="@+id/tvEncontrados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ENCONTRADOS: 0"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="12dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Movimentados -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:background="#FFF8E1">

                <TextView
                    android:id="@+id/tvMovimentados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MOVIMENTADOS: 0"
                    android:textColor="#F9A825"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="12dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Não encontrados -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                android:layout_marginStart="4dp"
                android:background="#FFEBEE">

                <TextView
                    android:id="@+id/tvNaoEncontrados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NÃO ENCONTRADOS: 0"
                    android:textColor="#C62828"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="12dp"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>