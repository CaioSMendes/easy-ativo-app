<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#252525"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_logo_bsb_rfid"
            android:scaleType="fitCenter"/>

        <TextView
            android:text="Configurações"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        card_view:cardCornerRadius="12dp"
        card_view:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Ícone -->
            <ImageView
                android:id="@+id/iconSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_config"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"/>

            <!-- Ambiente -->
            <TextView
                android:text="Ambiente da API"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Switch
                android:id="@+id/switchAmbiente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usar Homologação"/>

            <!-- Ambiente atual -->
            <TextView
                android:id="@+id/txtAmbiente"
                android:text="Ambiente: PRODUÇÃO"
                android:textStyle="bold"
                android:textColor="#444"
                android:textSize="16sp"
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- URL -->
            <TextView
                android:id="@+id/txtUrl"
                android:text="https://brasiliarfid.com.br/assejus/"
                android:textColor="#0072C6"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnSync"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Sincronizar"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_sync"
                android:layout_marginTop="20dp"/>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Sair"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_sair"
                android:layout_marginTop="20dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>