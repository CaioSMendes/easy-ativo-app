<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="80dp"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground"
    android:clipToPadding="false">

    <!-- Imagem do ativo -->
    <ImageView
        android:id="@+id/imgPatrimonioInventario"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_etiqueta"
        android:contentDescription="Imagem do Patrimônio"
        android:scaleType="centerCrop"
        android:layout_marginEnd="12dp"
        android:background="@drawable/circle_background"
        android:padding="4dp"/>

    <!-- Dados do ativo -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvDescricaoInventario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descrição do ativo"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#333333"
            android:maxLines="2"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvEpcInventario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EPC da Tag"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#777777"/>

        <TextView
            android:id="@+id/tvLocal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Local"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#777777"/>

        <TextView
            android:id="@+id/tvStatusInventario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</LinearLayout>
